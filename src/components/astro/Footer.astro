---
import DefaultFooter from "@astrojs/starlight/components/Footer.astro";
---

<DefaultFooter {...Astro.props} />

<div class="custom-footer">
  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
  </div>
  <p class="footer-description">
    © 2026 SriGuide - Free & Open Source <br />
    Project by <a href="https://github.com/Camino-lk/" target="_blank">
      <img class="camino-footer-img" src="/img/Camino.svg" alt="Camino Logo" />
    </a>
  </p>
</div>

<style>
  .custom-footer {
    text-align: center;
    padding: 2rem 1rem;
    padding-bottom: 0rem;
    border-top: 1px solid var(--sl-color-gray-6);
    color: var(--sl-color-gray-4);
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .footer-links a {
    color: var(--sl-color-gray-3);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--sl-color-text-accent);
    font-weight: 600;
  }

  .custom-footer p a {
    color: var(--sl-color-text-accent);
  }

  .footer-description {
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
    line-height: 2;
    margin-top: 1rem;
  }
  .footer-description a {
    text-decoration: none;
  }
  .footer-description .camino-footer-img {
    height: 0.8rem;
    padding-left: 4px;
  }
  .footer-description .camino-footer-img:hover {
    filter: brightness(0.8);
    transition: filter 0.2s;
  }
  .footer-description a:hover {
    text-decoration: underline;
  }
</style>
