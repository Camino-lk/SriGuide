---
/*
 * Props:
 *   title   (required) - The title of the card
 *   icon    (optional) - Name of the icon to display (from Starlight icons)
 *   href    (optional) - URL to link to when the card is clicked
 *   variant (optional) - Card style variants ("warn", "danger")
 *   stat    (optional) - Status badge ("new", "review", "draft")
 */

import { Icon, Badge } from "@astrojs/starlight/components";

const { title, icon, href, variant, stat } = Astro.props;
---

<a class={`card ${variant ?? ""}`} href={href}>
  {
    icon && (
      <div class="icon-wrapper">
        <Icon name={icon} class="icon" />
      </div>
    )
  }

  <h3 class="cursive-text card-title">
    {title}
    &nbsp;
    {
      stat?.toLowerCase() === "review" && (
        <Badge class="card-badge" text="Under Review" variant="tip" />
      )
    }
    {
      stat?.toLowerCase() === "new" && (
        <Badge class="card-badge" text="New" variant="success" />
      )
    }
    {
      stat?.toLowerCase() === "draft" && (
        <Badge class="card-badge" text="Draft" variant="caution" />
      )
    }
  </h3>
  <div class="content">
    <slot />
  </div>
</a>

<style>
  .card {
    position: relative;
    display: block;
    padding: 1.4rem;
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    transition:
      transform 0.2s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }
  .card .card-badge {
    margin: auto;
  }
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--sl-color-accent);
    box-shadow: 0 5px 20px
      color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
  }

  .icon-wrapper {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    margin-bottom: 0.6rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-6);
  }

  .icon {
    width: 20px;
    height: 20px;
    color: var(--sl-color-accent);
  }

  /* title */
  .card h3 {
    margin: 0 0 0.35rem 0;
    font-size: 1.5rem;
    font-weight: 300;
  }

  /* description */
  .content {
    font-size: 0.92rem;
    color: var(--sl-color-text-secondary);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(
      120deg,
      transparent,
      var(--sl-color-accent),
      transparent
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .card:hover::before {
    opacity: 0.25;
  }

  /* WARNING */

  .card.warn {
    border-color: var(--sl-color-orange-low);
    background:
      linear-gradient(var(--sl-color-orange-low), transparent 120px),
      var(--sl-color-bg);
  }

  .card.warn::before {
    background: linear-gradient(
      120deg,
      transparent,
      var(--sl-color-orange),
      transparent
    );
  }

  .card.warn:hover {
    border-color: var(--sl-color-orange);
    box-shadow: 0 5px 20px
      color-mix(in srgb, var(--sl-color-orange) 20%, transparent);
  }

  .card.warn .icon {
    color: var(--sl-color-orange);
  }

  /* DANGER */

  .card.danger {
    border-color: var(--sl-color-red-low);
    background:
      linear-gradient(var(--sl-color-red-low), transparent 120px),
      var(--sl-color-bg);
  }

  .card.danger::before {
    background: linear-gradient(
      120deg,
      transparent,
      var(--sl-color-red),
      transparent
    );
  }

  .card.danger:hover {
    border-color: var(--sl-color-red);
    box-shadow: 0 5px 20px
      color-mix(in srgb, var(--sl-color-red) 20%, transparent);
  }

  .card.danger .icon {
    color: var(--sl-color-red);
  }
</style>
