---
const { fallbackRate, fallbackDate } = Astro.props;
---

<div class="money-card">
  <img
    src="/img/Price-Board.avif"
    alt="A local vegetable price board in Sri Lanka with the rupee symbol"
    title="A local vegetable price board in Sri Lanka with the rupee symbol"
    class="side-image"
    loading="lazy"
  />
  <div class="converter">
    <div class="row">
      <label for="amount" class="sr-only">Amount</label>
      <input
        id="amount"
        type="number"
        value="1"
        min="0"
        step="any"
        aria-label="Amount in selected currency"
      />

      <label for="currency" class="sr-only">Currency</label>
      <select id="currency" aria-label="Select currency">
        <option value="" disabled selected>Loading currencies...</option>
      </select>

      <div class="lkr-box">
        <span id="result">...</span> LKR
      </div>
    </div>

    <div class="chips">
      <span id="status" class="chip">Loading rates...</span>
      <span class="chip source">
        Data:
        <a
          href="https://www.exchangerate-api.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          ExchangeRate API
        </a>
      </span>
    </div>
  </div>
</div>

<script>
  const amountInput = document.getElementById("amount") as HTMLInputElement;
  const currencySelect = document.getElementById(
    "currency",
  ) as HTMLSelectElement;
  const resultBox = document.getElementById("result")!;
  const statusChip = document.getElementById("status")!;

  let rates: Record<string, number> = {};
  const FALLBACK_RATE = 318.13; // ----------------------- Fallback USD to LKR rate
  const FALLBACK_DATE = "2026-04-26"; // -------------- Date of the fallback rate

  async function loadRates(forceFresh = false) {
    statusChip.innerText = "Checking rates...";

    // Try cache first
    const cached = localStorage.getItem("fxRates");
    if (cached && !forceFresh) {
      const {
        rates: cachedRates,
        nextUpdateUnix,
        lastUpdatedUnix,
      } = JSON.parse(cached);
      const now = Date.now() / 1000;

      // Use API's own next-update time to see if cache is still valid
      if (nextUpdateUnix && now < nextUpdateUnix) {
        rates = cachedRates;
        populateCurrencies();
        update();
        statusChip.innerText = `Updated: ${new Date(lastUpdatedUnix * 1000).toLocaleString()}`;
        statusChip.classList.remove("offline");
        return;
      }
    }

    // Cache invalid or missing → fetch fresh
    try {
      const res = await fetch("https://open.er-api.com/v6/latest/USD", {
        cache: "no-store",
      });
      if (!res.ok) throw new Error("Network response not ok");

      const data = await res.json();
      if (data.result !== "success") throw new Error("API error");

      rates = data.rates;
      const nextUpdateUnix = data.time_next_update_unix;
      const lastUpdatedUnix = data.time_last_update_unix;

      // Save data
      localStorage.setItem(
        "fxRates",
        JSON.stringify({
          rates,
          nextUpdateUnix,
          lastUpdatedUnix,
          timestamp: Date.now(),
        }),
      );

      populateCurrencies();
      update();
      statusChip.innerText = `Updated: ${new Date(lastUpdatedUnix * 1000).toLocaleString()}`;
      statusChip.classList.remove("offline");
    } catch (err) {
      console.log("Currency rate fetch failed.");

      // Fallback to cached (hard refresh)
      if (cached) {
        const { rates: cachedRates, lastUpdatedUnix } = JSON.parse(cached);
        rates = cachedRates;
        populateCurrencies();
        update();
        statusChip.innerText = `Offline — Last Known: ${new Date(lastUpdatedUnix * 1000).toLocaleString()}`;
        statusChip.classList.add("offline");
        return;
      }

      // Hardcoded data fallback
      rates = { USD: 1, LKR: FALLBACK_RATE };
      populateCurrencies();
      update();
      statusChip.innerText = `Offline — using rate on (${FALLBACK_DATE})`;
      statusChip.classList.add("offline");
    }
  }

  function populateCurrencies() {
    currencySelect.innerHTML =
      '<option value="" disabled selected>Select currency</option>';
    const sorted = Object.keys(rates).sort();
    sorted.forEach((code) => {
      const opt = document.createElement("option");
      opt.value = code;
      opt.textContent = code;
      currencySelect.appendChild(opt);
    });
    currencySelect.value = "USD";
  }

  function update() {
    const amount = parseFloat(amountInput.value) || 0;
    const currency = currencySelect.value;

    if (!currency || !rates[currency]) {
      resultBox.innerText = "...";
      return;
    }

    const usdToForeign = rates[currency];
    if (!usdToForeign) {
      resultBox.innerText = "Invalid Rate";
      return;
    }
    const foreignToUsd = 1 / usdToForeign;
    const usdToLkr = rates.LKR || FALLBACK_RATE;
    const lkrResult = amount * foreignToUsd * usdToLkr;

    const formatted = new Intl.NumberFormat(undefined, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(lkrResult);
    resultBox.innerText = "~ " + formatted;
  }

  amountInput.addEventListener("input", update);
  currencySelect.addEventListener("change", update);

  loadRates(false);
</script>

<style>
  .money-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 16px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-nav);
    position: relative;
    overflow: hidden;
    box-shadow: var(--sl-shadow-md);
  }

  .money-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      color-mix(in srgb, var(--sl-color-accent) 18%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  .side-image {
    width: 140px;
    min-width: 140px;
    height: auto;
    object-fit: cover;
    border-radius: 12px;
  }

  .converter {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  select,
  input {
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    font-size: 1rem;
    color: var(--sl-color-text);
    margin-top: 0px;
  }

  input {
    width: 100px;
    text-align: right;
  }

  .lkr-box {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    margin-top: 0px;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    font-weight: 600;
    white-space: nowrap;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .chip {
    font-size: 0.8rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text-secondary);
    border: 1px solid var(--sl-color-gray-5);
  }

  .chip.offline {
    background: color-mix(in srgb, var(--sl-color-red) 15%, var(--sl-color-bg));
    color: var(--sl-color-text);
    border-color: color-mix(in srgb, var(--sl-color-red) 40%, transparent);
  }

  .source a {
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .money-card {
      flex-direction: column;
    }
    .side-image {
      width: 100%;
      height: 120px;
    }
    .row {
      flex-direction: column;
      align-items: stretch;
    }
    input {
      width: 100%;
      text-align: left;
    }
  }
</style>
