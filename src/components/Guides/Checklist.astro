---
/*
 * Props:
 *   title (optional) — Checklist title ("Checklist" [def])
 *   items (optional) — Array of strings representing the checklist items
 *   id    (optional) — Unique identifier, used for state persistence. ("checklist" [def])
 */

const { title = "Checklist", items = [], id = "checklist" } = Astro.props;
---

<div
  class="checklist-card"
  data-id={id}
  role="region"
  aria-labelledby={`checklist-title-${id}`}
>
  <div class="header">
    <strong class="title" id={`checklist-title-${id}`}>{title}</strong>
    <span
      class="progress"
      id={`progress-${id}`}
      role="status"
      aria-live="polite"
      aria-atomic="true"></span>
  </div>

  <ul class="list" id={`list-${id}`} role="list" aria-label={`${title} items`}>
    {
      items.map((item: string, index: number) => (
        <li draggable="true" role="listitem" aria-label={item}>
          <span
            class="drag-handle"
            role="button"
            tabindex="0"
            aria-roledescription="drag handle"
            aria-label={`Reorder item: ${item}`}
            title="Drag to reorder"
          >
            <svg
              width="10"
              height="16"
              viewBox="0 0 10 16"
              fill="currentColor"
              aria-hidden="true"
            >
              <circle cx="2" cy="2" r="1.5" />
              <circle cx="8" cy="2" r="1.5" />
              <circle cx="2" cy="8" r="1.5" />
              <circle cx="8" cy="8" r="1.5" />
              <circle cx="2" cy="14" r="1.5" />
              <circle cx="8" cy="14" r="1.5" />
            </svg>
          </span>
          <input type="checkbox" id={`item-${id}-${index}`} aria-label={item} />
          <span
            class="item-text"
            role="textbox"
            contenteditable="true"
            aria-multiline="false"
            aria-label={`Edit item: ${item}`}
            aria-labelledby={`item-${id}-${index}`}
          >
            {item}
          </span>
          <button class="delete-btn" aria-label={`Remove item: ${item}`}>
            <svg
              width="10"
              height="10"
              viewBox="0 0 10 10"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="1" y1="1" x2="9" y2="9" />
              <line x1="9" y1="1" x2="1" y2="9" />
            </svg>
          </button>
        </li>
      ))
    }
  </ul>

  <div class="controls">
    <button class="add" aria-label={`Add new item to ${title}`}>
      <svg
        width="12"
        height="12"
        viewBox="0 0 12 12"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="6" y1="1" x2="6" y2="11"></line>
        <line x1="1" y1="6" x2="11" y2="6"></line>
      </svg>
      Add item
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".checklist-card").forEach((card) => {
    const id = card.dataset.id;
    const list = card.querySelector<HTMLUListElement>(".list")!;
    const progress = card.querySelector<HTMLSpanElement>(".progress")!;
    const addBtn = card.querySelector<HTMLButtonElement>(".add");

    if (!id || !list || !progress || !addBtn) return;

    const storageKey = "checklist-" + id;

    // ── Persist ──────────────────────────────────────────────
    function save() {
      const data: { text: string; done: boolean }[] = [];
      list.querySelectorAll<HTMLLIElement>("li").forEach((li) => {
        const text = li.querySelector<HTMLSpanElement>(".item-text");
        const checkbox = li.querySelector<HTMLInputElement>("input");
        if (!text || !checkbox) return;
        data.push({
          text: text.textContent?.trim() ?? "",
          done: checkbox.checked,
        });
      });
      localStorage.setItem(storageKey, JSON.stringify(data));
      updateProgress();
    }

    function updateProgress() {
      const allItems = list.querySelectorAll<HTMLLIElement>("li");
      const total = allItems.length;
      let done = 0;
      allItems.forEach((li) => {
        if (li.querySelector<HTMLInputElement>("input")?.checked) done++;
      });

      if (total === 0) {
        progress.textContent = "";
        progress.removeAttribute("data-complete");
        return;
      }

      progress.textContent = `${done} / ${total} completed`;
      progress.toggleAttribute("data-complete", done === total && total > 0);
    }

    // ── Create item ──────────────────────────────────────────
    function createItem(text = "", done = false, focus = false) {
      const li = document.createElement("li");
      li.draggable = true;

      li.innerHTML = `
        <span class="drag-handle" aria-hidden="true">
          <svg width="10" height="16" viewBox="0 0 10 16" fill="currentColor">
            <circle cx="2" cy="2"  r="1.5"/>
            <circle cx="8" cy="2"  r="1.5"/>
            <circle cx="2" cy="8"  r="1.5"/>
            <circle cx="8" cy="8"  r="1.5"/>
            <circle cx="2" cy="14" r="1.5"/>
            <circle cx="8" cy="14" r="1.5"/>
          </svg>
        </span>
        <input type="checkbox" ${done ? "checked" : ""}>
        <span class="item-text" contenteditable="true">${text}</span>
        <button class="delete-btn" aria-label="Remove item">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="1" y1="1" x2="9" y2="9"/>
            <line x1="9" y1="1" x2="1" y2="9"/>
          </svg>
        </button>
      `;

      list.appendChild(li);
      attachEvents(li);
      save();

      if (focus) {
        const span = li.querySelector<HTMLSpanElement>(".item-text");
        if (span) {
          span.focus();
          // Select all text so the user can type immediately
          const range = document.createRange();
          range.selectNodeContents(span);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    }

    // ── Drag: only allow drag when handle is grabbed ─────────
    let dragFromHandle = false;

    function attachEvents(li: HTMLLIElement) {
      const checkbox = li.querySelector<HTMLInputElement>("input");
      const textSpan = li.querySelector<HTMLSpanElement>(".item-text");
      const del = li.querySelector<HTMLButtonElement>(".delete-btn");
      const handle = li.querySelector<HTMLSpanElement>(".drag-handle");

      if (!checkbox || !textSpan || !del || !handle) return;

      checkbox.addEventListener("change", () => {
        li.classList.toggle("done", checkbox.checked);
        li.setAttribute(
          "aria-label",
          `${textSpan.innerText.trim()}, ${checkbox.checked ? "completed" : "not completed"}`,
        );
        save();
      });
      // Reflect persisted state immediately on load
      li.classList.toggle("done", checkbox.checked);

      textSpan.addEventListener("input", () => {
        const newText = textSpan.innerText.trim();
        li.setAttribute("aria-label", newText || "Empty item");
        checkbox.setAttribute("aria-label", newText || "Empty item");
        del.setAttribute(
          "aria-label",
          `Remove item: ${newText || "Empty item"}`,
        );
        handle.setAttribute(
          "aria-label",
          `Reorder item: ${newText || "Empty item"}`,
        );
        save();
      });

      // Confirm delete on Enter, blur on Escape
      textSpan.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter") {
          e.preventDefault();
          textSpan.blur();
        }
        if (e.key === "Escape") {
          textSpan.blur();
        }
      });

      del.addEventListener("click", () => {
        li.classList.add("removing");
        li.addEventListener(
          "animationend",
          () => {
            li.remove();
            save();
          },
          { once: true },
        );
      });

      // Only allow drag when the handle is the source
      handle.addEventListener("mousedown", () => {
        dragFromHandle = true;
      });
      handle.addEventListener(
        "touchstart",
        () => {
          dragFromHandle = true;
        },
        { passive: true },
      );

      li.addEventListener("dragstart", (e: DragEvent) => {
        if (!dragFromHandle) {
          e.preventDefault();
          return;
        }
        // Small timeout so the browser can snapshot the element before fade it
        requestAnimationFrame(() => li.classList.add("dragging"));
        e.dataTransfer?.setDragImage(li, 20, li.offsetHeight / 2);
      });

      li.addEventListener("dragend", () => {
        dragFromHandle = false;
        li.classList.remove("dragging");
        save();
      });
    }

    // ── Drop zone ────────────────────────────────────────────
    list.addEventListener("dragover", (e: DragEvent) => {
      e.preventDefault();
      const dragging = list.querySelector<HTMLLIElement>(".dragging");
      if (!dragging) return;

      // Use getBoundingClientRect for accurate viewport-relative positions
      const siblings = [
        ...list.querySelectorAll<HTMLLIElement>("li:not(.dragging)"),
      ];
      const after = siblings.find((li) => {
        const rect = li.getBoundingClientRect();
        return e.clientY < rect.top + rect.height / 2;
      });

      if (after) list.insertBefore(dragging, after);
      else list.appendChild(dragging);
    });

    // ── Add button ───────────────────────────────────────────
    addBtn.addEventListener("click", () => {
      createItem("New item", false, true);
    });

    // ── Load persisted state ─────────────────────────────────
    const saved = localStorage.getItem(storageKey);
    if (saved) {
      list.innerHTML = "";
      const parsed: { text: string; done: boolean }[] = JSON.parse(saved);
      parsed.forEach((i) => createItem(i.text, i.done));
    } else {
      list.querySelectorAll<HTMLLIElement>("li").forEach(attachEvents);
      updateProgress();
    }
  });
</script>

<style is:global>
  /* ── Card shell ─────────────────────────────────────────── */
  .checklist-card {
    padding: 1.2rem 1.3rem 1rem;
    border-radius: 14px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-nav);
    position: relative;
    overflow: hidden;
  }

  .checklist-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      color-mix(in srgb, var(--sl-color-accent) 12%, transparent),
      transparent 65%
    );
    pointer-events: none;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .checklist-card .header {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.85rem;
  }

  .checklist-card .title {
    font-size: 0.95rem;
    line-height: 1.3;
  }

  .checklist-card .progress {
    font-size: 0.75rem;
    color: var(--sl-color-text-accent);
    opacity: 0.7;
    transition:
      color 0.2s,
      opacity 0.2s;
    min-height: 1em;
  }

  .checklist-card .progress[data-complete] {
    color: var(--sl-color-text-accent);
    opacity: 1;
  }

  /* ── List ───────────────────────────────────────────────── */
  .checklist-card .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .checklist-card .list li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0px;
    padding: 0.2rem;
    border-radius: 7px;
    border: 1px solid transparent;
    transition:
      background 0.15s,
      border-color 0.15s,
      opacity 0.15s;
  }

  .checklist-card .list li:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 6%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
  }

  .checklist-card .list li:hover .drag-handle {
    opacity: 0.45;
  }

  .checklist-card .list li.dragging {
    opacity: 0.35;
    cursor: grabbing;
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
  }

  .checklist-card .list li.removing {
    animation: removeItem 0.2s ease forwards;
  }

  @keyframes removeItem {
    to {
      opacity: 0;
      transform: translateX(6px);
      max-height: 0;
      padding: 0;
      margin: 0;
    }
  }

  /* ── Drag handle ────────────────────────────────────────── */
  .checklist-card .drag-handle {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: var(--sl-color-text-secondary);
    opacity: 0.15;
    cursor: grab;
    transition: opacity 0.15s;
    touch-action: none;
  }

  .checklist-card .drag-handle:active {
    cursor: grabbing;
  }

  /* ── Checkbox ───────────────────────────────────────────── */
  .checklist-card .list input[type="checkbox"] {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    accent-color: var(--sl-color-accent);
    cursor: pointer;
  }

  /* ── Item text ──────────────────────────────────────────── */
  .checklist-card .item-text {
    flex: 1;
    min-width: 0;
    font-size: 0.88rem;
    line-height: 1.4;
    outline: none;
    word-break: break-word;
    border-radius: 4px;
    padding: 1px 3px;
    margin: -1px -3px;
    transition: background 0.15s;
  }

  .checklist-card .item-text:focus {
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  .checklist-card li.done .item-text {
    text-decoration: line-through;
    opacity: 0.5;
  }

  /* ── Delete button ──────────────────────────────────────── */
  .checklist-card .delete-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    margin-bottom: 0px;
    border: none;
    border-radius: 5px;
    background: none;
    cursor: pointer;
    color: var(--sl-color-text-secondary);
    opacity: 0;
    transition:
      opacity 0.15s,
      background 0.15s,
      color 0.15s;
  }

  .checklist-card .list li:hover .delete-btn {
    opacity: 0.5;
  }

  .checklist-card .delete-btn:hover {
    opacity: 1 !important;
    background: color-mix(in srgb, red 12%, transparent);
    color: #ef4444;
  }

  /* ── Add button ─────────────────────────────────────────── */
  .checklist-card .controls {
    margin-top: 0.65rem;
    padding-top: 0.55rem;
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .checklist-card .add {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: none;
    background: none;
    padding: 0.3rem 0.45rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--sl-color-text-secondary);
    transition:
      background 0.15s,
      color 0.15s;
  }

  .checklist-card .add:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }
</style>
