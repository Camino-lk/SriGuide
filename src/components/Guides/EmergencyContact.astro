---
/**
 * Props:
 *   name      (required) — Display name of the contact
 *   phone     (required) — Phone number, in E.164 format e.g. "+66 1155"
 *   country   (optional) — Country label shown in the card
 *   note      (optional) — Short description shown below the name
 *   category  (optional) — "police" | "medical" | "fire" | "embassy" | "general" [def]
 */

interface Props {
  name: string;
  phone: string;
  country?: string;
  note?: string;
  category?: "police" | "medical" | "fire" | "embassy" | "general";
}

const { name, phone, country, note, category = "general" } = Astro.props;

// Strip everything except digits and leading + for the tel: href
const phoneClean = phone.replace(/[^\d+]/g, "");
const telHref = phoneClean.startsWith("+")
  ? `tel:${phoneClean}`
  : `tel:${phoneClean}`;

// Unique ID per instance so multiple cards on one page don't conflict
const uid = `ec-${Math.random().toString(36).slice(2, 8)}`;

const icons: Record<string, string> = {
  police: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4 2 7L12 17l-6.5 3 2-7L2 9h7z"/></svg>`,
  medical: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  fire: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 3z"/></svg>`,
  embassy: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  general: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14v2.92z"/></svg>`,
};

const accentVars: Record<string, string> = {
  police: "--ec-accent: #3b82f6; --ec-accent-bg: rgba(59,130,246,.08);",
  medical: "--ec-accent: #ef4444; --ec-accent-bg: rgba(239,68,68,.08);",
  fire: "--ec-accent: #f97316; --ec-accent-bg: rgba(249,115,22,.08);",
  embassy: "--ec-accent: #8b5cf6; --ec-accent-bg: rgba(139,92,246,.08);",
  general: "--ec-accent: #10b981; --ec-accent-bg: rgba(16,185,129,.08);",
};

const icon = icons[category];
const accentStyle = accentVars[category];

// VCF format
const vcfLines = [
  "BEGIN:VCARD",
  "VERSION:3.0",
  `FN:${name}${country ? ` (${country})` : ""}`,
  `N:${name};;;;`,
  `TEL;TYPE=VOICE,CELL:${phoneClean}`,
  "ORG:SriGuide",
  note ? `NOTE:${note}` : "",
  "CATEGORIES:EMERGENCY",
  "X-SOCIALPROFILE;type=travel-guide:SriGuide",
  "END:VCARD",
]
  .filter(Boolean)
  .join("\r\n");
---

<div
  id={uid}
  class="ec-card"
  style={accentStyle}
  data-name={name}
  data-country={country ?? ""}
  data-vcf={vcfLines}
  data-phone={phoneClean}
>
  <!-- Icon badge -->
  <span class="ec-icon" aria-hidden="true" set:html={icon} />

  <!-- Info -->
  <div class="ec-info">
    <div class="ec-header">
      <span class="ec-name">{name}</span>
      {country && <span class="ec-country">{country}</span>}
    </div>
    {note && <p class="ec-note">{note}</p>}
    <a class="ec-phone" href={telHref}>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path
          d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14v2.92z"
        ></path></svg
      >
      {phone}
    </a>
  </div>

  <!-- Actions -->
  <div class="ec-actions">
    <!-- Save to Contacts (.vcf download) -->
    <button
      class="ec-btn ec-btn-save"
      type="button"
      aria-label={`Save ${name} to contacts`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"
        ></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline
          points="7 3 7 8 15 8"></polyline></svg
      >
      Save
    </button>

    <!-- Share (Web Share API → .vcf fallback) -->
    <button
      class="ec-btn ec-btn-share"
      type="button"
      aria-label={`Share ${name} contact`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"
        ></circle><circle cx="18" cy="19" r="3"></circle><line
          x1="8.59"
          y1="13.51"
          x2="15.42"
          y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"
        ></line></svg
      >
      Share
    </button>
  </div>
</div>

<style>
  .ec-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--ec-accent);
    border-left: 4px solid var(--ec-accent);
    border-radius: 0.5rem;
    background: var(--ec-accent-bg);
    margin-block: 1rem;
    flex-wrap: wrap;
  }

  .ec-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--ec-accent);
    color: #fff;
    padding: 0.45rem;
  }

  .ec-icon svg {
    width: 100%;
    height: 100%;
  }

  .ec-info {
    flex: 1;
    min-width: 0;
  }

  .ec-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .ec-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--sl-color-white, inherit);
    line-height: 1.3;
  }

  .ec-country {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ec-accent);
    background: var(--ec-accent-bg);
    border: 1px solid var(--ec-accent);
    border-radius: 999px;
    padding: 0.1em 0.55em;
  }

  .ec-note {
    margin: 0.15rem 0 0.25rem;
    font-size: 0.8rem;
    color: var(--sl-color-gray-3, #888);
    line-height: 1.4;
  }

  .ec-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.88rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--ec-accent);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .ec-phone:hover {
    text-decoration: underline;
  }

  .ec-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .ec-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    margin-top: 0rem;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    border: 1.5px solid var(--ec-accent);
    background: transparent;
    color: var(--ec-accent);
    transition:
      background 0.15s,
      color 0.15s;
    white-space: nowrap;
  }

  .ec-btn:hover {
    background: var(--ec-accent);
    color: #fff;
  }

  .ec-btn:active {
    opacity: 0.85;
  }

  /* Subtle success flash */
  .ec-btn.ec-success {
    background: var(--ec-accent);
    color: #fff;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll<HTMLElement>(".ec-card").forEach((card) => {
      const vcf = card.dataset.vcf ?? "";
      const name = card.dataset.name ?? "Emergency Contact";
      const country = card.dataset.country ?? "";
      const phone = card.dataset.phone ?? "";

      const label = country ? `${name} (${country})` : name;
      const filename = `${label.replace(/[^a-z0-9]/gi, "_")}.vcf`;

      /** Trigger a .vcf file download */
      function downloadVcf(): void {
        const blob = new Blob([vcf], { type: "text/vcard;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = Object.assign(document.createElement("a"), {
          href: url,
          download: filename,
        });
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 5_000);
      }

      /** Flash a button green briefly */
      function flash(btn: HTMLButtonElement): void {
        btn.classList.add("ec-success");
        setTimeout(() => btn.classList.remove("ec-success"), 1_500);
      }

      // ── Save button: always downloads the .vcf ──────────────────────────
      const saveBtn = card.querySelector<HTMLButtonElement>(".ec-btn-save");
      saveBtn?.addEventListener("click", () => {
        downloadVcf();
        if (saveBtn) flash(saveBtn);
      });

      // ── Share button: Web Share API with .vcf file, text fallback ────────
      const shareBtn = card.querySelector<HTMLButtonElement>(".ec-btn-share");
      shareBtn?.addEventListener("click", async () => {
        const canShareFiles =
          typeof navigator.share === "function" &&
          typeof navigator.canShare === "function";

        if (canShareFiles) {
          // Prefer sharing the actual .vcf file so the OS opens it as a contact
          const vcfFile = new File([vcf], filename, { type: "text/vcard" });

          const shareData: ShareData = navigator.canShare({ files: [vcfFile] })
            ? { files: [vcfFile], title: label }
            : {
                title: label,
                text: `${label}\n${phone}`,
              };

          try {
            await navigator.share(shareData);
            if (shareBtn) flash(shareBtn);
          } catch (err) {
            // User cancelled — no action
            if ((err as DOMException).name !== "AbortError") {
              console.error(
                "Error while sharing contact. Falling back to .vcf download.",
              );
              downloadVcf();
            }
          }
        } else {
          // No Web Share API (=desktop browser)
          console.log(
            "Web Share API not supported or cannot share files; falling back to .vcf download",
          );
          downloadVcf();
          if (shareBtn) flash(shareBtn);
        }
      });
    });
  });
</script>
